NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose)
DATABASE_URL="postgresql://dito:dito_secret@localhost:5432/dito_db"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dito-assets
S3_REGION=us-east-1

# AI
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant
QDRANT_URL=http://localhost:6333

# CORS
CORS_ORIGIN=http://localhost:4200

# Upload limits (bytes)
MAX_FILE_SIZE=104857600
